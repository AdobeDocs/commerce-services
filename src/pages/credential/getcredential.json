        "components": {
          "SignIn": {
            "title": "Get credentials",
            "paragraph": "After signing in, you can create credentials that can be used to call the Catalog Data Ingestion REST API.",
            "buttonText": "Sign in"
          },
          "Form": {
            "title": "Get credentials",
            "paragraph": "Create credentials that you can use to call the Catalog Data Ingestion REST API. You also need the sandbox instance ID to call the API.",
            "className": "formClass",
            "components": {
              "CredentialName": {
                "label": "Credential name",
                "description": "The credential name must be unique, use alphanumeric characters, and between 6 and 45 characters long. A project will be automatically created with the same name in Adobe Developer Console.",
                "range": "45"
              },
              "Products": {
                "label": "Included products and services",
                "items": [
                  {
                    "Product": {
                      "label": "Adobe Commerce Optimizer",
                      "icon": "https://raw.githubusercontent.com/AdobeDocs/commerce-services/main/src/pages/credential/images/commerce.svg"
                    }
                  }
                ]
              },
              "AdobeDeveloperConsole": {
                "label": "By checking this box, you agree to",
                "linkText": "Adobe Developer Terms of Use",
                "href": "https://wwwimages2.adobe.com/content/dam/cc/en/legal/servicetou/Adobe-Developer-Additional-Terms_en-US_20230822.pdf"
              },
              "Side": {
                "content": {
                  "style": {
                    "display": "flex",
                    "gap": "32px",
                    "flexDirection": "column"
                  },
                  "elements": [
                    {
                      "type": "h3",
                      "className": "spectrum-Heading spectrum-Heading--sizeS side-header",
                      "text": "OAuth server-to-server credential"
                    },
                    {
                      "type": "p",
                      "className": "spectrum-Body spectrum-Body--sizeM",
                      "text": "This credential allows you to use industry standard OAuth2.0 libraries to generate access tokens using the OAuth 2.0 client credentials grant type."
                    },
                    {
                      "type": "p",
                      "className": "spectrum-Body spectrum-Body--sizeM",
                      "text": "This credential only provides an access token. It does not return the instance ID associated with your Adobe Commerce Optimizer sandbox environment, which is required for API calls. In addition to the access token, you must copy your Instance ID from the Commerce Cloud Manager and paste it into the tenantID field in the Try it panel below."
                    },
                    {
                      "type": "h3",
                      "className": "spectrum-Heading spectrum-Heading--sizeS side-header",
                      "text": "Learn more"
                    },
                    {
                      "type": "a",
                      "className": "spectrum-Link",
                      "text": "Authentication documentation",
                      "href": "https://developer.adobe.com/commerce/services/optimizer/data-ingestion/authentication/"
                    }
                  ]
                }
              }
            }
          },
